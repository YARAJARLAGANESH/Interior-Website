# ============================================
# INTERIOR WEBSITE - FRONTEND
# Environment Configuration Template
# ============================================
# Copy this file to .env.local and fill in actual values

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
# For development: http://localhost:5001/api
# For production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5001/api

# ============================================
# APP ENVIRONMENT
# ============================================
# Vite automatically sets import.meta.env.MODE
# development or production
VITE_ENVIRONMENT=development
