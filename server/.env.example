# ============================================
# INTERIOR WEBSITE - ADMIN DASHBOARD
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5001

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB connection URI
# Example: mongodb://username:password@host:port/database
# For local development: mongodb://localhost:27017/interior-admin
MONGO_URI=mongodb://localhost:27017/interior-admin

# ============================================
# JWT AUTHENTICATION
# ============================================
# Secret key for signing JWT tokens (should be a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# For development: http://localhost:5173,http://localhost:5174
# For production: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================
# CLOUDINARY (Image/Video Upload)
# ============================================
# Get these from your Cloudinary dashboard: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Set in client/.env or client/.env.local
VITE_API_URL=http://localhost:5001/api
